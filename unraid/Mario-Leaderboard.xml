<?xml version="1.0"?>
<Container version="2">
  <Name>Mario-Leaderboard</Name>
  <Repository>ghcr.io/articwone/mario-leaderboard:latest</Repository>
  <Registry>https://ghcr.io/articwone/mario-leaderboard</Registry>
  <Network>bridge</Network>
  <MyIP/>
  <Shell>sh</Shell>
  <Privileged>false</Privileged>
  <Support>https://github.com/ArticWone/Mario-Leaderboard</Support>
  <Project>https://github.com/ArticWone/Mario-Leaderboard</Project>
  <Overview>Docker-only Mario leaderboard site with local JSON score storage.</Overview>
  <Category>GameServers: Web:</Category>
  <WebUI>http://[IP]:[PORT:80]/</WebUI>
  <TemplateURL/>
  <Icon>https://raw.githubusercontent.com/ArticWone/Mario-Leaderboard/main/assets/favicon-192.png</Icon>
  <ExtraParams/>
  <PostArgs/>
  <CPUset/>
  <DateInstalled/>
  <DonateText/>
  <DonateLink/>
  <Requires/>
  <Config Name="WebUI" Target="80" Default="18673" Mode="tcp" Description="HTTP port for the Mario leaderboard site." Type="Port" Display="always" Required="true" Mask="false">18673</Config>
  <Config Name="Score Data" Target="/data" Default="/mnt/user/appdata/Mario-Leaderboard" Mode="rw" Description="Persistent writable score storage. The container writes scores.json here." Type="Path" Display="always" Required="true" Mask="false">/mnt/user/appdata/Mario-Leaderboard</Config>
</Container>
